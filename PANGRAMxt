                                            PANGRAM:
                                      =====================

                                      
------->>>>>    A sentence using every letter of the alphabet at least once
__________________________________________________________________________________



#include <stdio.h>

#include <string.h>

#include <ctype.h>


int isPangram(char *str) 
{
    int seen[26] = {0};
    
    for (int i = 0; str[i]; i++)
    
        if (isalpha(str[i]))
        
            seen[tolower(str[i]) - 'a'] = 1;
            

    for (int i = 0; i < 26; i++)
    
        if (!seen[i]) return 0;
        
    return 1;
}

void printMissing(char *str)
{
    int seen[26] = {0};
    
    for (int i = 0; str[i]; i++)
    
        if (isalpha(str[i]))
        
            seen[tolower(str[i]) - 'a'] = 1;
            

    printf("Missing letters: ");
    
    int any = 0;
    
    for (int i = 0; i < 26; i++)
    
        if (!seen[i])
        { printf("%c ", 'a' + i); any = 1;
        }
    if (!any) printf("None");
    
    printf("\n");
    
}

int main()
{
    char str[200];
    
    printf("Enter a sentence: ");
    
    fgets(str, sizeof(str), stdin);
    
    str[strcspn(str, "\n")] = '\0';

    if (isPangram(str))
    
        printf("The sentence IS a pangram!\n");
        
    else {
        printf("The sentence is NOT a pangram.\n");
        
        printMissing(str);
        
    }
    return 0;
}


